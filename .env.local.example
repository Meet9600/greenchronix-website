# GreenBytes — Environment Variables
# Copy this file to .env.local for local development.
# Set the same keys in your Vercel project (Settings → Environment Variables).

# Required for the /api/contact route to send emails.
# Get yours at https://resend.com → API Keys (free tier: 3,000 emails/month).
# If this is not set, the contact form will automatically fall back to WhatsApp.
RESEND_API_KEY=

# Where contact form submissions are delivered.
# If unset, defaults to siteConfig.email from app/lib/site.ts.
CONTACT_TO_EMAIL=hello@greenbytes.dev

# Sender address shown in the email's "From" field.
# Format: "Display Name <verified@yourdomain.com>"
#
# To use your own domain (recommended for production):
#   1. In Resend, go to Domains → Add Domain
#   2. Add the DNS records they give you to your domain provider
#   3. Once verified, set this to e.g. "GreenBytes <hello@greenbytes.com>"
#
# If unset, defaults to "GreenBytes <onboarding@resend.dev>" which works
# immediately but emails will look generic (no custom domain in From).
RESEND_FROM=
